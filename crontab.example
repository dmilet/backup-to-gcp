#!/bin/bash

# Cron job helper script for automated backups
# Copy this to /etc/cron.d/backup-to-gcp or use with crontab

# Set environment
export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
export PATH=/usr/local/bin:/usr/bin:/bin

# Backup job - runs daily at 2 AM
0 2 * * * backup /home/user/backup-to-gcp/backup_utility.py my-backup-bucket /home/user/documents >> /var/log/gcp-backup.log 2>&1

# Alternative: Run backup with email notification on success/failure
# 0 2 * * * cd /home/user/backup-to-gcp && python3 backup_utility.py my-backup-bucket /home/user/documents 2>&1 | mail -s "GCP Backup Report" admin@example.com

# Note: Adjust the times and paths to match your setup
# To install this for your user crontab:
# crontab -e
# Then paste the relevant lines (without the header comment)
